@page "/order"
@attribute [StreamRendering]

<PageTitle>Order Pizza</PageTitle>

<h1>Order Your Pizza</h1>

<div class="order-container">

    <div class="order-form">
        <label>Select Pizza:</label>
        <select @bind="selectedPizza">
            @foreach (var pizza in pizzas)
            {
                <option value="@pizza.Name">@pizza.Name</option>
            }
        </select>

        <label>Quantity:</label>
        <input type="number" min="1" @bind="quantity" />

        <button class="btn btn-primary" @onclick="SubmitOrder">Place Order</button>

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="mt-3 order-message">@message</p>
        }
    </div>

    <div class="order-preview">
        <h3>Preview</h3>
        <img src="@selectedPizzaImage" class="preview-img" />
    </div>

</div>

@code {
    private int quantity = 1;
    private string selectedPizza = "Pepperoni";
    private string? message;

    private List<Pizza> pizzas = new()
    {
        new Pizza("Pepperoni", "images/pepperoni.jpg"),
        new Pizza("Hawaiian", "images/hawaiian.jpg"),
        new Pizza("Veggie", "images/veggie.jpg"),
        new Pizza("Cheese Lovers", "images/cheese.jpg")
    };

    private string selectedPizzaImage => pizzas.First(p => p.Name == selectedPizza).Image;

    private void SubmitOrder()
    {
        message = $"Thank you! You ordered {quantity} {selectedPizza} pizza(s).";
    }

    public record Pizza(string Name, string Image);
}
