@using Microsoft.AspNetCore.Components.Web
@page "/menu"
@attribute [StreamRendering]

<PageTitle>Pizza Menu</PageTitle>

<h1 class="menu-title">Blazing Pizza</h1>

<div class="menu-container">
    <div class="menu-grid">
        @foreach (var pizza in pizzas)
        {
            <div class="pizza-card">
                <img src="@pizza.ImageUrl" alt="@pizza.Name" class="pizza-img" />
                <div class="pizza-info">
                    <h3>@pizza.Name</h3>
                    <p>@pizza.Description</p>
                    <span class="price">@pizza.Price.ToString("C")</span>
                    <button class="btn btn-danger" @onclick="() => AddToOrder(pizza)">Add to Order</button>
                </div>
            </div>
        }
    </div>

    <div class="order-panel">
        <h3>Your Order</h3>
        @if (order.Count == 0)
        {
            <p>No items yet.</p>
        }
        else
        {
            <ul>
                @foreach (var item in order)
                {
                    <li>@item.Name - @item.Price.ToString("C")</li>
                }
            </ul>
            <p class="total">Total: @order.Sum(p => p.Price).ToString("C")</p>
            <button class="btn btn-primary">Pay @order.Sum(p => p.Price).ToString("C")</button>
        }
    </div>
</div>

@code {
    private List<Pizza> pizzas = new()
    {
        new Pizza("Buffalo Chicken", "images/buffalo.jpg", 19.95m, "Spicy chicken with buffalo sauce"),
        new Pizza("The Bacon Cheese", "images/bacon.jpg", 19.95m, "Loaded with bacon and cheese"),
        new Pizza("Veggie Delight", "images/veggie.jpg", 19.95m, "Fresh vegetables and herbs"),
        new Pizza("Classic Pepperoni", "images/pepperoni.jpg", 19.95m, "Traditional pepperoni and cheese"),
        new Pizza("Black Cherry Pizza", "images/cherry.jpg", 19.95m, "Sweet and savory cherry topping"),
        new Pizza("Margherita", "images/margherita.jpg", 19.95m, "Tomato, mozzarella, and basil")
    };

    private List<Pizza> order = new();

    private void AddToOrder(Pizza pizza)
    {
        order.Add(pizza);
    }

    public record Pizza(string Name, string ImageUrl, decimal Price, string Description);
}
